<!-- NAV BAR -->

<!-- =========================
     SHARED SITE NAVIGATION
     desktop + mobile
     ========================= -->
<nav class="site-nav">

  <!-- =========================
       DESKTOP NAVIGATION
       visible on larger screens
       ========================= -->
  <div class="site-nav__desktop">

    <!-- brand / logo -->
    <a href="/" class="site-nav__brand">
      <span class="site-nav__brand-light">Commencement</span>
      <span class="site-nav__brand-bold">2026</span>
    </a>

    <!-- desktop navigation links -->
    <div class="site-nav__links">
      <a href="/">Livestreams</a>
      <a href="/">Highlights</a>
      <a href="/">Speakers</a>
      <a href="/">Video</a>
      <a href="/">Social</a>
      <a href="/">Photos</a>
      <a href="/">Honors</a>
    </div>

    <!-- right side changes depending on login state -->
    <% if (user) { %>
      <!-- desktop user dropdown -->
      <details class="site-nav__user-menu site-nav__user-menu--desktop">
        <summary class="site-nav__user-trigger">
          <!-- avatar circle with first initial -->
          <span class="site-nav__avatar">
            <%= user.username.charAt(0).toUpperCase() %>
          </span>

          <!-- username -->
          <span class="site-nav__username">
            <%= user.username %>
          </span>
        </summary>

        <!-- dropdown card -->
        <div class="site-nav__dropdown">
          <!-- user info -->
          <div class="site-nav__dropdown-header">
            <div class="site-nav__dropdown-name">
              <%= user.username %>
            </div>

            <div class="site-nav__dropdown-email">
              Signed in user
            </div>

            <div class="site-nav__dropdown-role">
              Admin
            </div>
          </div>

          <!-- user actions -->
          <div class="site-nav__dropdown-links">
            <a href="/awardees">Manage Awardees</a>
            <a href="/awardees/new">Create New Awardee</a>
            <a href="/auth/sign-out">Sign Out</a>
          </div>
        </div>
      </details>
    <% } else { %>
      <!-- desktop auth links -->
      <div class="site-nav__auth">
        <a href="/auth/sign-up">Sign Up</a>
        <a href="/auth/sign-in">Sign In</a>
      </div>
    <% } %>
  </div>

  <!-- =========================
       MOBILE TOP BAR
       visible on smaller screens
       ========================= -->
  <div class="site-nav__mobile-top">

    <!-- mobile brand -->
    <a href="/" class="site-nav__brand site-nav__brand--mobile">
      <span class="site-nav__brand-light">Commencement</span>
      <span class="site-nav__brand-bold">2026</span>
    </a>

    <% if (user) { %>
      <!-- mobile dropdown for signed-in users -->
      <details class="site-nav__user-menu site-nav__user-menu--mobile">
        <summary class="site-nav__mobile-actions">
          <!-- user avatar -->
          <span class="site-nav__avatar">
            <%= user.username.charAt(0).toUpperCase() %>
          </span>

          <!-- hamburger icon -->
          <span class="site-nav__menu-button" aria-label="Open menu">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </summary>

        <!-- mobile dropdown menu -->
        <div class="site-nav__dropdown site-nav__dropdown--mobile">

          <!-- user info at top of mobile dropdown -->
          <div class="site-nav__dropdown-header">
            <div class="site-nav__dropdown-name">
              <%= user.username %>
            </div>

            <div class="site-nav__dropdown-email">
              Signed in user
            </div>

            <div class="site-nav__dropdown-role">
              Admin
            </div>
          </div>

          <!-- main site navigation links -->
          <div class="site-nav__dropdown-links">
            <a href="/">Livestreams</a>
            <a href="/">Highlights</a>
            <a href="/">Speakers</a>
            <a href="/">Video</a>
            <a href="/">Social</a>
            <a href="/">Photos</a>
            <a href="/">Honors</a>
          </div>

          <!-- admin actions -->
          <div class="site-nav__dropdown-links">
            <a href="/awardees">Manage Awardees</a>
            <a href="/awardees/new">Create New Awardee</a>
            <a href="/auth/sign-out">Sign Out</a>
          </div>
        </div>
      </details>
    <% } else { %>
      <!-- mobile dropdown for guests -->
      <details class="site-nav__user-menu site-nav__user-menu--mobile">
        <summary class="site-nav__mobile-actions">
          <!-- simple menu button for guests -->
          <span class="site-nav__menu-button" aria-label="Open menu">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </summary>

        <!-- guest mobile dropdown -->
        <div class="site-nav__dropdown site-nav__dropdown--mobile">
          <!-- main site navigation links -->
          <div class="site-nav__dropdown-links">
            <a href="/">Livestreams</a>
            <a href="/">Highlights</a>
            <a href="/">Speakers</a>
            <a href="/">Video</a>
            <a href="/">Social</a>
            <a href="/">Photos</a>
            <a href="/">Honors</a>
          </div>

          <!-- guest auth actions -->
          <div class="site-nav__dropdown-links">
            <a href="/auth/sign-up">Sign Up</a>
            <a href="/auth/sign-in">Sign In</a>
          </div>
        </div>
      </details>
    <% } %>
  </div>

</nav>