<!-- NAV BAR -->
<nav class="site-nav">

  <!-- =========================
       DESKTOP NAVIGATION
       ========================= -->
  <div class="site-nav__desktop">

    <!-- Logo / Brand (left side) -->
    <a href="/" class="site-nav__brand">
      <span class="site-nav__brand-light">Commencement</span>
      <span class="site-nav__brand-bold">2026</span>
    </a>

    <!-- Main navigation links (center) -->
    <div class="site-nav__links">
      <a href="/">Livestreams</a>
      <a href="/">Highlights</a>
      <a href="/">Speakers</a>
      <a href="/">Video</a>
      <a href="/">Social</a>
      <a href="/">Photos</a>
      <a href="/">Honors</a>
    </div>

    <!-- RIGHT SIDE: depends on if user is logged in -->
    <% if (user) { %>

      <!-- =========================
           USER DROPDOWN MENU (DESKTOP)
           ========================= -->

      <!-- "details" = built-in dropdown behavior (no JS needed)
           "summary" = what you click to open it -->
      <details class="site-nav__user-menu site-nav__user-menu--desktop">

        <!-- This is what the user sees in the nav -->
        <summary class="site-nav__user-trigger">
          
          <!-- Circle avatar with first letter -->
          <span class="site-nav__avatar">
            <%= user.username.charAt(0).toUpperCase() %>
          </span>

          <!-- Username next to avatar -->
          <span class="site-nav__username">
            <%= user.username %>
          </span>
        </summary>

        <!-- DROPDOWN CARD -->
        <div class="site-nav__dropdown">

          <!-- Top section: user info -->
          <div class="site-nav__dropdown-header">
            <div class="site-nav__dropdown-name">
              <%= user.username %>
            </div>

            <!-- You can later replace this with real email -->
            <div class="site-nav__dropdown-email">
              Signed in user
            </div>

            <div class="site-nav__dropdown-role">
              Admin
            </div>
          </div>

          <!-- Bottom section: actions -->
          <div class="site-nav__dropdown-links">

            <!-- Goes to protected CRUD page -->
            <a href="/awardees">Manage Awardees</a>

            <!-- Logs the user out -->
            <a href="/auth/sign-out">Sign Out</a>

          </div>
        </div>
      </details>

    <% } else { %>

      <!-- =========================
           NOT LOGGED IN (DESKTOP)
           ========================= -->

      <div class="site-nav__auth">
        <a href="/auth/sign-up">Sign Up</a>
        <a href="/auth/sign-in">Sign In</a>
      </div>

    <% } %>
  </div>

  <!-- =========================
       MOBILE NAVIGATION (TOP BAR)
       ========================= -->
  <div class="site-nav__mobile-top">

    <!-- Logo on mobile -->
    <a href="/" class="site-nav__brand site-nav__brand--mobile">
      <span class="site-nav__brand-light">Commencement</span>
      <span class="site-nav__brand-bold">2026</span>
    </a>

    <% if (user) { %>

      <!-- =========================
           USER MENU (MOBILE)
           ========================= -->

      <!-- Same idea: details = dropdown -->
      <details class="site-nav__user-menu site-nav__user-menu--mobile">

        <!-- Top-right clickable area -->
        <summary class="site-nav__mobile-actions">

          <!-- Avatar -->
          <span class="site-nav__avatar">
            <%= user.username.charAt(0).toUpperCase() %>
          </span>

          <!-- Hamburger menu icon -->
          <span class="site-nav__menu-button" aria-label="Open menu">
            <span></span>
            <span></span>
            <span></span>
          </span>

        </summary>

        <!-- Dropdown content -->
        <div class="site-nav__dropdown site-nav__dropdown--mobile">

          <!-- User info -->
          <div class="site-nav__dropdown-header">
            <div class="site-nav__dropdown-name">
              <%= user.username %>
            </div>

            <div class="site-nav__dropdown-email">
              Signed in user
            </div>

            <div class="site-nav__dropdown-role">
              Admin
            </div>
          </div>

          <!-- Actions -->
          <div class="site-nav__dropdown-links">
            <a href="/awardees">Manage Awardees</a>
            <a href="/auth/sign-out">Sign Out</a>
          </div>

        </div>
      </details>

    <% } else { %>

      <!-- Not logged in (mobile) -->
      <div class="site-nav__mobile-actions">
        <a href="/auth/sign-in">Sign In</a>
      </div>

    <% } %>
  </div>

  <!-- Small mobile subnav (like your Livestreams dropdown label) -->
  <div class="site-nav__mobile-subnav">
    <span>Livestreams</span>
    <span class="site-nav__chevron">⌄</span>
  </div>

</nav>