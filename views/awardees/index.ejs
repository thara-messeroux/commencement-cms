<!-- this page shows the logged-in user's (admin) awardees.
it lets them view, create, edit, and delete awardees. -->
<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/_head.ejs") %>

  <body>
    <%- include("../partials/_nav.ejs") %>

    <main>
      <h1>Manage Awardees</h1>

      <!-- this link opens the form to create a new awardee -->
      <p>
        <a href="/awardees/new">Create New Awardee</a>
      </p>

      <!-- if there are no awardees yet, show a friendly message -->
      <% if (awardees.length === 0) { %>
        <p>No awardees yet.</p>
      <% } else { %>
        <ul>
          <% awardees.forEach((awardee) => { %>
            <li>
              <!-- each awardee name links to its detail page -->
              <a href="/awardees/<%= awardee._id %>">
                <%= awardee.name %> - <%= awardee.degree %>
              </a>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </main>
  </body>
</html>