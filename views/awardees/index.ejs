<!-- this page shows a list of all the awardees in the database, 
 with links to their individual pages. 
 it also has a link to create a new awardee. -->
<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/_head.ejs") %>
  <body>
    <%- include("../partials/_nav.ejs") %>

    <main>
      <h1>Manage Awardees</h1>

      <p><a href="/awardees/new">Create New Awardee</a></p>

      <% if (awardees.length === 0) { %>
        <p>No awardees yet.</p>
      <% } else { %>
        <ul>
          <% awardees.forEach((awardee) => { %>
            <li>
              <a href="/awardees/<%= awardee._id %>">
                <%= awardee.name %> - <%= awardee.degree %>
              </a>
            </li>
          <% }) %>
        </ul>
      <% } %>
    </main>
  </body>
</html>