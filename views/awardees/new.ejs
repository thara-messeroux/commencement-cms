<!-- layman's terms: this page has a form to create a new awardee. 
 the form submits a POST request to /awardees, which is handled by the awardees controller. -->
<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/_head.ejs") %>
  <body>
    <%- include("../partials/_nav.ejs") %>

    <main>`
      <h1>Create Awardee</h1>

      <!-- form to create a new awardee -->
      <form action="/awardees" method="POST">
        <label>
          Name
          <input type="text" name="name" required />
        </label>

        <label>
          Degree
          <input type="text" name="degree" required />
        </label>

        <label>
          Year
          <input type="number" name="year" required />
        </label>

        <label>
          Bio
          <textarea name="bio"></textarea>
        </label>

        <button type="submit">Create Awardee</button>
      </form>
    </main>
  </body>
</html>