<!-- this page has a form to edit an existing awardee. 
 the form submits a PUT request to /awardees/:id, which is handled by the awardees controller. -->
<!DOCTYPE html>
 <!DOCTYPE html>
<html lang="en">
  <%- include("../partials/_head.ejs") %>
  <body>
    <%- include("../partials/_nav.ejs") %>

    <main>
      <h1>Edit Awardee</h1>

      <!-- form to update an existing awardee -->
      <form action="/awardees/<%= awardee._id %>?_method=PUT" method="POST">
        <label>
          Name
          <input type="text" name="name" value="<%= awardee.name %>" required />
        </label>

        <label>
          Degree
          <input type="text" name="degree" value="<%= awardee.degree %>" required />
        </label>

        <label>
          Year
          <input type="number" name="year" value="<%= awardee.year %>" required />
        </label>

        <label>
          Bio
          <textarea name="bio"><%= awardee.bio %></textarea>
        </label>

        <button type="submit">Update Awardee</button>
      </form>
    </main>
  </body>
</html>