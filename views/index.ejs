<!-- this is the homepage of the site. 
 it shows a hero section with a big image and some text, 
 and then a preview of featured awardees below. 
 the awardees are passed in from the server when rendering this page. -->
<!DOCTYPE html>
<html lang="en">
  <%- include("partials/_head.ejs") %>

  <body>
    <%- include("partials/_nav.ejs") %>

    <main class="landing-page">
      <!-- hero = the big welcome area -->
      <section class="header-hero">
        <div class="header-hero-shell">
          <div class="live-video-block">
            <!-- image layer -->
            <div class="media-placeholder">
              <!-- local video = safer for demo -->
              <video
                class="hero-video"
                autoplay
                muted
                loop
                playsinline
              >
                <source src="/videos/hero-video.mp4" type="video/mp4">
                Your browser does not support the video tag.
              </video>
            </div>
            <!-- dark fade = helps white text stay readable -->
            <div class="hero-overlay"></div>

            <!-- hero text box -->
            <div class="frame-7067">
              <div class="hero-copy">
                <h1 class="hero-title">
                  <span class="hero-title-emphasis">Relive</span>
                  <span class="hero-title-rest"> the excitement</span>
                </h1>

                <p class="hero-subtitle">
                  Rewatch Commencement streams anytime, anywhere.
                </p>

                <a href="#featured-awardees" class="button-primary">
                  Watch replays
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- keep awardees working below hero -->
      <section id="featured-awardees" class="landing-awardees-preview">
        <div class="content-shell">
          <h2 class="preview-heading">Featured Awardees</h2>

          <!-- show a message if there are no awardees yet -->
          <% if (awardees.length === 0) { %>
            <p class="empty-state">No awardees to display yet.</p>
          <% } else { %>
            <ul class="awardee-preview-list">
              <% awardees.forEach((awardee) => { %>
                <li class="awardee-preview-item">
                  <a href="/awardees/<%= awardee._id %>" class="awardee-preview-link">
                    <span class="awardee-preview-name"><%= awardee.name %></span>
                    <span class="awardee-preview-meta">
                      <%= awardee.degree %> (<%= awardee.year %>)
                    </span>
                  </a>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </div>
      </section>
    </main>
  </body>
</html>